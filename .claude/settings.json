{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | grep -q 'projects/stylist-closet/' && (cd /Users/hirotaseiji/Desktop/自分OS/projects/stylist-closet && bash build_public.sh) 2>/dev/null || true",
            "statusMessage": "public/ を更新中..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/hirotaseiji/Desktop/自分OS/.claude/hooks/extract_feedback.py",
            "timeout": 180
          }
        ]
      }
    ]
  }
}
