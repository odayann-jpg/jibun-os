{
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"【現在日時 / Current Date-Time】$(date '+%Y-%m-%d (%a) %H:%M:%S %Z')  ※システムリマインダーの Today's date より、こちらを優先する\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash /Users/hirotaseiji/Desktop/自分OS/scripts/inbox-headline.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "date '+【現在日時】%Y-%m-%d (%a) %H:%M %Z'",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | grep -q 'projects/stylist-closet/' && (cd /Users/hirotaseiji/Desktop/自分OS/projects/stylist-closet && bash build_public.sh) 2>/dev/null || true",
            "statusMessage": "public/ を更新中..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/hirotaseiji/Desktop/自分OS/.claude/hooks/extract_feedback.py",
            "timeout": 180
          }
        ]
      }
    ]
  }
}
